<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="cadastro.css">
    <title>Central de Cadastro</title>
</head>
<body>
    <div class="cadastro">
        <h1>Central de Cadastro</h1>
        <form id="meuFormulario">
            <input type="text" id="nome" placeholder="Exemplo: João Silva" required> 
            <input type="text" id="email" placeholder="Exemplo: joao@email.com">
            <input type="text" id="telefone" placeholder="Exemplo: (11) 99999-9999">
            <input type="text" id="cep" placeholder="Exemplo: 01001-000" onblur="verificarEBuscarCEP()">
            <input type="text" id="logradouro" placeholder="Logradouro" >
            <input type="text" id="bairro" placeholder="Bairro" >
            <input type="text" id="cidade" placeholder="Cidade" >
            <input type="text" id="estado" placeholder="Estado" >
            <input type="text" id="numero" placeholder="Número" >
            <button type="submit">Cadastrar</button>
        </form>

        <a href="lista.html" style="text-decoration: none;"><button type="button" id="btn-ver-cadastros">Ver Cadastros</button></a>
    </div>

    <script>
        function buscarLogradouro(cep) {
            const cepLimpo = document.getElementById("cep").value
            return fetch(`https://viacep.com.br/ws/${cepLimpo}/json/`)
                .then(response => response.json())
        }
        async function verificarEBuscarCEP() {
            const cepRaw = document.getElementById("cep").value;
            const cep = cepRaw.replace(/\D/g, ''); // Remove caracteres não numéricos
                if (cep.length !== 8) {
                    return;
                }
                try {
                    const data = await buscarLogradouro(cep);
                    if (!data || data.erro === true || data.erro === "true") {
                        alert("Este CEP não existe na base de dados dos Correios! Verifique o número.");
                        return;
                }
                    document.getElementById("logradouro").value = data.logradouro;
                    document.getElementById("bairro").value = data.bairro;
                    document.getElementById("cidade").value = data.localidade;
                    document.getElementById("estado").value = data.uf;
                    document.getElementById('numero').focus(); // Foca no campo de número após preencher os dados do endereço
                
                } catch (error) {
                    console.error("Erro ao buscar o CEP:", error);
                    alert("Ocorreu um erro ao buscar o CEP. Tente novamente mais tarde.");
                }
        }
        document.getElementById('meuFormulario').addEventListener('submit', function(event) {
            event.preventDefault();// Impede a página de recarregar

            const nome = document.getElementById("nome").value.trim();
            const email = document.getElementById("email").value.trim();
            const telefone = document.getElementById("telefone").value.trim();
            const cep = document.getElementById("cep").value.replace(/\D/g, ''); // Remove caracteres não numéricos do CEP
            const logradouro = document.getElementById("logradouro").value.trim();
            const bairro = document.getElementById("bairro").value.trim();
            const cidade = document.getElementById("cidade").value.trim();
            const estado = document.getElementById("estado").value.trim();
            const numero = document.getElementById("numero").value.trim();

             // Validação básica do nome
            if (nome.trim().length === 0) {
                alert("Nome inválido!");
                return;
            }
            // Validação básica do email (apenas formato)
            if (email.trim().length === 0 || !email.includes("@")) {
                alert("Email inválido!");
                return;
            }
            // Validação básica do telefone (apenas formato)
            if (telefone.trim().length === 0) {
                alert("Telefone inválido!");
                return;
            }
            // Validação básica do CEP (apenas formato)
            if (cep.trim().length !== 8) {
                alert("CEP inválido! O CEP deve conter 8 dígitos.");
                return;
            }
            const novoUsuario = {
                nome: nome,
                email: email,
                telefone: telefone,
                cep: cep,
                logradouro: logradouro,
                bairro: bairro,
                cidade: cidade,
                estado: estado,
                numero: numero
            };
            let listaUsuarios = JSON.parse(localStorage.getItem("usuarios")) || [];
            
            listaUsuarios.push(novoUsuario);

            localStorage.setItem("usuarios", JSON.stringify(listaUsuarios));
            alert("Cadastro realizado com sucesso!");
            
            this.reset(); // Limpa o formulário após o cadastro
            
            window.location.href = "lista.html"; // Redireciona para a página de lista de cadastros
        });
    </script>
</body>
</html>
