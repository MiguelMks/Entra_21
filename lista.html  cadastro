<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="cadastro.css">
    <title>Lista de Cadastros</title>
</head>
<body>
    <div class="cadastro">
        <h1>Usuários Cadastrados</h1>
        <a href="index.html" style="text-decoration: none;"><button type="button">Voltar para Cadastro</button></a>
    </div>
    
    <br>
    <div id="visualizacao" class="cadastro-mural"></div>

    <div class="overlay" id="overlay"></div>
    <div class="edicao-container" id="edicaoContainer">
        <h2>Editar Cadastro</h2>
        <input type="text" id="editNome" placeholder="Nome">
        <input type="text" id="editEmail" placeholder="Email">
        <input type="text" id="editTelefone" placeholder="Telefone">
        <input type="text" id="editCep" placeholder="CEP" onblur="verificarEBuscarCEPEdicao()">
        <input type="text" id="editLogradouro" placeholder="Logradouro">
        <input type="text" id="editBairro" placeholder="Bairro">
        <input type="text" id="editCidade" placeholder="Cidade">
        <input type="text" id="editEstado" placeholder="Estado">
        <input type="text" id="editNumero" placeholder="Número">

        <div class="botoes-edicao">
            <button class="cancelar" onclick="cancelarEdicao()">Cancelar</button>
            <button class="salvar" onclick="salvarEdicao()">Salvar</button>
        </div>
    </div>

    <div class="overlay" id="overlayExclusao"></div>
    <div class="confirmacao-container" id="confirmacaoContainer">
        <h2>Tem certeza de excluir esse usuário?</h2>
        <p>Esta ação não pode ser desfeita.</p>
        <div class="botoes-confirmacao">
            <button class="cancelar" onclick="cancelarExclusao()">Cancelar</button>
            <button class="excluir" onclick="confirmarExclusao()">Excluir</button>
        </div>
    </div>

    <script>
        let indiceEmEdicao = null;
        let indiceParaExcluir = null;

        // Executa assim que a página termina de carregar
        window.onload = function() {
            // 1. Seleciona o elemento onde os cadastros serão exibidos
            const visualizacao = document.getElementById("visualizacao");
            // 2. Pegar os dados do localStorage
            const listaUsuarios = JSON.parse(localStorage.getItem("usuarios")) || [];

            // 3. Verificar se há dados salvos
            if (listaUsuarios.length === 0) {
               visualizacao.innerHTML = `<p style="text-align:center; width: 100%; color: black">Nenhum cadastro encontrado.</p>`;
               return;
            }

            // 4. Limpa a div antes de renderizar para não duplicar dados
            visualizacao.innerHTML = "";

            // 5. Percorrer a lista e adicionar as linhas na visualização
            listaUsuarios.forEach((usuario, index) => {
                visualizacao.innerHTML += `
                    <div class="cadastro-cliente">
                        <h2>${usuario.nome}</h2>
                        <p><strong>Email:</strong> ${usuario.email}</p>
                        <p><strong>Telefone:</strong> ${usuario.telefone}</p>
                        <p><strong>CEP:</strong> ${usuario.cep}</p>
                        <button type="button" onclick="abrirEdicao(${index})" style="background-color: midnightblue; color: white;">Editar</button>
                        <button type="button" onclick="excluirCadastro(${index})" style="background-color: red; color: white;">Excluir</button>
                    </div>
                `;
            });
        };

        // Função para buscar o logradouro usando a API do ViaCEP
        function buscarLogradouro(cep) {
            const cepLimpo = cep.replace(/\D/g, ''); // Remove caracteres não numéricos

            if (cepLimpo.length !== 8) {
                alert("CEP inválido! O CEP deve conter 8 dígitos.");
                return Promise.reject("Formato de CEP inválido");
            }

            return fetch(`https://viacep.com.br/ws/${cepLimpo}/json/`)
                .then(response => response.json())
                .catch(error => {
                    console.error("Erro ao buscar o CEP:", error);
                    alert("Ocorreu um erro ao buscar o CEP. Tente novamente mais tarde.");
                });
        }

        // CORRIGIDO: Nome sem caracteres especiais e mapeamento correto da variável cepRaw
        async function verificarEBuscarCEPEdicao() {
            const cepRaw = document.getElementById("editCep").value;
            const cepLimpo = cepRaw.replace(/\D/g, ''); 

            if (cepLimpo.length !== 8) { return; }

            try {
                const data = await buscarLogradouro(cepLimpo);
                // CORRIGIDO: Lógica de negação correta para verificar se a API retornou erro
                if (!data || data.erro === true || data.erro === "true") {
                    alert("CEP não encontrado!");
                    return;
                } 
                document.getElementById("editLogradouro").value = data.logradouro || "";
                document.getElementById("editBairro").value = data.bairro || "";
                document.getElementById("editCidade").value = data.localidade || "";
                document.getElementById("editEstado").value = data.uf || "";
                document.getElementById('editNumero').focus(); 
            } catch (error) {
                console.error(error);
            }
        }

        function excluirCadastro(index) {
            indiceParaExcluir = index;
            document.getElementById("confirmacaoContainer").classList.add("ativo");
            document.getElementById("overlayExclusao").classList.add("ativo");
        }

        function confirmarExclusao() {
            let listaUsuarios = JSON.parse(localStorage.getItem("usuarios")) || [];
            listaUsuarios.splice(indiceParaExcluir, 1);
            localStorage.setItem("usuarios", JSON.stringify(listaUsuarios));
            window.location.reload();
        }

        function cancelarExclusao() {
            document.getElementById("confirmacaoContainer").classList.remove("ativo");
            document.getElementById("overlayExclusao").classList.remove("ativo");
            indiceParaExcluir = null;
        }

        function abrirEdicao(index) {
            let listaUsuarios = JSON.parse(localStorage.getItem("usuarios")) || [];
            const usuario = listaUsuarios[index];
            indiceEmEdicao = index;

            document.getElementById("editNome").value = usuario.nome;
            document.getElementById("editEmail").value = usuario.email;
            document.getElementById("editTelefone").value = usuario.telefone;
            document.getElementById("editCep").value = usuario.cep;
            document.getElementById("editLogradouro").value = usuario.logradouro || "";
            document.getElementById("editBairro").value = usuario.bairro || "";
            document.getElementById("editCidade").value = usuario.cidade || "";
            document.getElementById("editEstado").value = usuario.estado || "";
            document.getElementById("editNumero").value = usuario.numero || "";
            
            document.getElementById("edicaoContainer").classList.add("ativo");
            document.getElementById("overlay").classList.add("ativo");
        }

        function cancelarEdicao() {
            document.getElementById("editNome").value = "";
            document.getElementById("editEmail").value = "";
            document.getElementById("editTelefone").value = "";
            document.getElementById("editCep").value = "";
            document.getElementById("editLogradouro").value = "";
            document.getElementById("editBairro").value = "";
            document.getElementById("editCidade").value = "";
            document.getElementById("editEstado").value = "";
            document.getElementById("editNumero").value = "";
            
            document.getElementById("edicaoContainer").classList.remove("ativo");
            document.getElementById("overlay").classList.remove("ativo");
            indiceEmEdicao = null;
        }

        async function salvarEdicao() {
            const novoNome = document.getElementById("editNome").value;
            const novoEmail = document.getElementById("editEmail").value;
            const novoTelefone = document.getElementById("editTelefone").value;
            const novoCep = document.getElementById("editCep").value.trim();
            const novoLogradouro = document.getElementById("editLogradouro").value;
            const novoBairro = document.getElementById("editBairro").value;
            const novaCidade = document.getElementById("editCidade").value;
            const novoEstado = document.getElementById("editEstado").value;
            const novoNumero = document.getElementById("editNumero").value;

            if (novoNome.trim().length === 0) {
                alert("Nome inválido!");
                return;
            }
            if (novoEmail.trim().length === 0 || !novoEmail.includes("@")) {
                alert("Email inválido!");
                return;
            }
            if (novoTelefone.trim().length === 0) {
                alert("Telefone inválido!");
                return;
            }
            if (novoCep.length !== 8 || isNaN(novoCep)) {
                alert("CEP Precisa de 8 caracteres numéricos!");
                return;
            }

            try {
                const data = await buscarLogradouro(novoCep);
                if (!data || data.erro === true || data.erro === "true") {
                    alert("CEP não encontrado!");
                    return;
                } 
            } catch (error) {
                console.error("Error:", error);
            }

            let listaUsuarios = JSON.parse(localStorage.getItem("usuarios")) || [];

            listaUsuarios[indiceEmEdicao] = {
                nome: novoNome,
                email: novoEmail,
                telefone: novoTelefone,
                cep: novoCep,
                logradouro: novoLogradouro,
                bairro: novoBairro,
                cidade: novaCidade,
                estado: novoEstado,
                numero: novoNumero
            };

            localStorage.setItem("usuarios", JSON.stringify(listaUsuarios));
            cancelarEdicao();
            window.location.reload();
        }
        </script>
</body>
</html>
