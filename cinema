    <script>
        function ocupar(botao) {
            if (botao.classList.contains('assento')) {
                botao.classList.replace('assento', 'escolhido');
            }
            else if (botao.classList.contains('ocupado')) {

            }
            else if (botao.classList.contains('escolhido')) {
                botao.classList.replace('escolhido', 'assento');
            }
            atualizarAssentos();
            
            function atualizarAssentos() {
                const escolhidos = document.querySelectorAll('.escolhido');
                const lista = document.getElementById('lista-assentos');

                let assentos = [];

                escolhidos.forEach((assento) => {
                    const fileira = assento.parentElement;
                    const numeroFileira = Array.from(fileira.parentElement.children).indexOf(fileira);

                    const letras = ['A', 'B', 'C', 'D', 'E', 'F', 'G'];

                    assentos.push(letras[numeroFileira] + assento.innerText);
                });

                if (assentos.length > 0) {
                    lista.innerText = assentos.join(', ');
                } else {
                    lista.innerText = 'Nenhum assento selecionado';
                }
                atualizarPreco();
                function atualizarPreco() {
                    const precoTotal = document.getElementById('precoTotal');
                    const precoPorAssento = 67;
                    const total = assentos.length * precoPorAssento;
                    precoTotal.innerText = 'R$ ' + total.toFixed(2);
            }
        }    
